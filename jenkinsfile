pipeline {
    agent any

    environment {
        IMAGE_NAME = "zerotrust-app"

        // Jenkins credential (Claude optional)
        ANTHROPIC_API_KEY = credentials('ANTHROPIC_API_KEY')

        // Windows local Ollama
        OLLAMA_URL   = "http://127.0.0.1:11434"
        OLLAMA_MODEL = "llama3.2:3b"

        AGENT_DIR   = "agent"
        REPORTS_DIR = "reports"
    }

    options {
        timeout(time: 60, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
    }

    stages {

        stage('0. Preparation') {
            steps {
                bat '''
                    echo === Zero Trust Pipeline ===
                    mkdir %REPORTS_DIR% 2>nul || echo exists
                    python --version
                    pip install requests rich semgrep anthropic 2>nul || echo skipping pip install
                '''

                bat '''
python -c "
import os, requests

print('=== IA CHECK ===')

api_key = os.environ.get('ANTHROPIC_API_KEY','')

if api_key and api_key.startswith('sk-ant-'):
    print('[OK] Claude API available')
else:
    print('[WARN] Claude API missing')

try:
    r = requests.get('http://127.0.0.1:11434/api/tags', timeout=5)
    print('[OK] Ollama available')
except:
    print('[WARN] Ollama not reachable')
"
                '''
            }
        }

        stage('1. SAST - Semgrep') {
            steps {
                bat '''
                    echo Running Semgrep...
                    semgrep --config=auto test-app --json > reports/semgrep.json || echo "semgrep failed"
                '''
            }
        }

        stage('2. SCA - Trivy') {
            steps {
                bat '''
                    echo Running Trivy...
                    trivy fs test-app --format json -o reports/trivy.json || echo "trivy failed"
                '''
            }
        }

        stage('3. AI Analysis (Ollama / Claude fallback)') {
            steps {
                bat '''
                    echo Running AI analysis...
                    python agent/ollama_client.py reports/trivy.json
                '''
            }
        }

        stage('4. Final Report') {
            steps {
                bat '''
                    echo === Pipeline completed ===
                    dir reports
                '''
            }
        }
    }

    post {
        always {
            echo "Zero Trust Pipeline finished"
        }

        success {
            echo "SUCCESS: pipeline passed"
        }

        failure {
            echo "FAILED: check logs"
        }
    }
}