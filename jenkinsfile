// devsecops-zero-trust-pipeline/Jenkinsfile
pipeline {
    agent any

    environment {
        IMAGE_NAME        = 'zerotrust-app'
        ANTHROPIC_API_KEY = credentials('ANTHROPIC_API_KEY')
        OLLAMA_URL        = 'http://ollama:11434'
        OLLAMA_MODEL      = 'llama3.2:3b'
        REPORTS_DIR       = 'reports'
    }

    options {
        timeout(time: 60, unit: 'MINUTES')
        timestamps()
        ansiColor('xterm')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {

        // ── Stage 0 : Préparation ──────────────────────────
        stage('0. Préparation') {
            steps {
                sh '''
                    mkdir -p ${REPORTS_DIR}
                    pip install --quiet semgrep anthropic rich requests 2>/dev/null || true
                    echo '=== Vérification moteurs IA ==='
                    python3 agent/ollama_client.py
                '''
            }
        }

        // ── Stage 1 : SAST Semgrep ─────────────────────────
        stage('1. SAST - Semgrep') {
            steps {
                sh '''
                    semgrep --config=auto test-app/ \
                        --json --output=${REPORTS_DIR}/semgrep-results.json \
                        --severity=WARNING || true
                    python3 -c "
import json
d=json.load(open('${REPORTS_DIR}/semgrep-results.json'))
print(f'Semgrep : {len(d.get(\"results\",[]))} probleme(s)')"
                '''
            }
            post {
                always {
                    archiveArtifacts artifacts: "${REPORTS_DIR}/semgrep-results.json",
                                     allowEmptyArchive: true
                }
            }
        }

        // ── Stages 2–5 : add your missing stages here ──────
        // stage('2. ...') { ... }
        // stage('3. ...') { ... }
        // stage('4. ...') { ... }
        // stage('5. ...') { ... }

        // ── Stage 6 : Signature Cosign ─────────────────────
        stage('6. Signature Cosign') {
            when { branch 'main' }
            steps {
                sh '''
                    if ! command -v cosign &>/dev/null; then
                        curl -sSfL https://github.com/sigstore/cosign/releases/latest/download/cosign-linux-amd64 \
                            -o /usr/local/bin/cosign && chmod +x /usr/local/bin/cosign
                    fi
                    echo "Pipeline Zero Trust complet - Build ${BUILD_NUMBER}"
                '''
            }
        }

    } // end stages

    post {
        always  { cleanWs() }
        success { echo 'Pipeline Zero Trust OK' }
        failure { echo 'Echec — voir les artifacts' }
    }

} // end pipeline