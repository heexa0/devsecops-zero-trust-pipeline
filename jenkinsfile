pipeline {
    agent any

    environment {
        IMAGE_NAME        = 'zerotrust-app'
        ANTHROPIC_API_KEY = credentials('ANTHROPIC_API_KEY')
        OLLAMA_URL        = 'http://ollama:11434'
        OLLAMA_MODEL      = 'llama3.2:3b'
        REPORTS_DIR       = 'reports'
    }

    options {
        timeout(time: 60, unit: 'MINUTES')
        timestamps()
        ansiColor('xterm')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {

        stage('0. Préparation') {
            steps {
                sh '''
                    if ! command -v python3 &>/dev/null; then
                        apt-get update -qq && apt-get install -y -qq python3 python3-pip
                    fi
                    mkdir -p ${REPORTS_DIR}
                    pip3 install --quiet semgrep anthropic rich requests 2>/dev/null || true
                    echo '=== Vérification moteurs IA ==='
                    python3 agent/ollama_client.py
                '''
            }
        }

        stage('1. SAST - Semgrep') {
            steps {
                sh '''
                    semgrep --config=auto test-app/ \
                        --json --output=${REPORTS_DIR}/semgrep-results.json \
                        --severity=WARNING || true
                    python3 -c "
import json
d=json.load(open('${REPORTS_DIR}/semgrep-results.json'))
print(f'Semgrep : {len(d.get(\"results\",[]))} probleme(s)')"
                '''
            }
            post {
                always {
                    archiveArtifacts artifacts: "${REPORTS_DIR}/semgrep-results.json",
                                     allowEmptyArchive: true
                }
            }
        }

        stage('2. SCA - Trivy') {
            steps {
                sh '''
                    if ! command -v trivy &>/dev/null; then
                        curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh \
                            | sh -s -- -b /usr/local/bin
                    fi
                    trivy fs ./test-app --format json \
                        --output ${REPORTS_DIR}/trivy-report.json \
                        --severity MEDIUM,HIGH,CRITICAL --quiet || true
                '''
            }
            post {
                always {
                    archiveArtifacts artifacts: "${REPORTS_DIR}/trivy-report.json",
                                     allowEmptyArchive: true
                }
            }
        }

        stage('3. AI Security Guard') {
            stages {
                stage('3a. Anti-Tampering') {
                    steps {
                        sh 'cp ${REPORTS_DIR}/trivy-report.json agent/ || true'
                        sh 'cp ${REPORTS_DIR}/semgrep-results.json agent/ || true'
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh 'cd agent && python3 antitamper_agent.py'
                        }
                    }
                }
                stage('3b. Remédiation CVE') {
                    steps {
                        sh 'cd agent && python3 remediation_agent.py'
                    }
                }
                stage('3c. Rapport Explicatif') {
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh 'cd agent && python3 explainer_agent.py'
                        }
                    }
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'agent/*.json,agent/*.md',
                                     allowEmptyArchive: true
                }
            }
        }

        stage('4. Build Docker') {
            steps {
                sh 'docker build -t ${IMAGE_NAME}:${BUILD_NUMBER} .'
            }
        }

        stage('5. Scan Image Docker') {
            steps {
                sh 'trivy image --severity CRITICAL --exit-code 0 ${IMAGE_NAME}:${BUILD_NUMBER}'
            }
        }

        stage('6. Signature Cosign') {
            when { branch 'main' }
            steps {
                sh '''
                    if ! command -v cosign &>/dev/null; then
                        curl -sSfL https://github.com/sigstore/cosign/releases/latest/download/cosign-linux-amd64 \
                            -o /usr/local/bin/cosign && chmod +x /usr/local/bin/cosign
                    fi
                    echo "Pipeline Zero Trust complet - Build ${BUILD_NUMBER}"
                '''
            }
        }

    } // end stages

    post {
        always  { deleteDir() }
        success { echo 'Pipeline Zero Trust OK' }
        failure { echo 'Echec — voir les artifacts' }
    }

} // end pipeline